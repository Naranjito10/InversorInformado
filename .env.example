# ===== Supabase =====
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR-SERVICE-ROLE-KEY

# ===== Scraping config =====
SCRAPER_INTERVAL_MINUTES=60
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_MAX_PAGES_PER_SEARCH=5
SCRAPER_USER_AGENT_ROTATE=true
# Comma-separated list of proxies: http://user:pass@host:port,http://...
SCRAPER_PROXIES=

# ===== Search targets (JSON list of URL templates per source) =====
# Example: barrios/municipios you want to monitor
# Format: source|search_url
SEARCH_TARGETS_FILE=config/search_targets.json

# ===== Notifications =====
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Alert thresholds =====
ALERT_MIN_SCORE_HIGH=80
ALERT_MIN_SCORE_PRICE_DROP=60
ALERT_PRICE_DROP_PCT=5.0

# ===== Logs =====
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.jsonl

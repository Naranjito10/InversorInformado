# ===== Supabase =====
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Usa la clave ANON (no service_role). Activa RLS en Supabase:
#   - listings: INSERT/UPDATE para el rol anon, SELECT restringido por politica.
# La service_role bypasea RLS y otorga acceso admin completo — nunca la expongas.
SUPABASE_KEY=YOUR-ANON-KEY

# ===== Scraping config =====
SCRAPER_INTERVAL_MINUTES=60
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
SCRAPER_MAX_PAGES_PER_SEARCH=5
SCRAPER_USER_AGENT_ROTATE=true
# Comma-separated list of proxies: http://user:pass@host:port,http://...
SCRAPER_PROXIES=
# Marcar anuncios como inactivos si no aparecen en el ciclo.
# Solo activar si max_pages cubre el total de resultados del target.
SCRAPER_MARK_INACTIVE=false

# ===== Search targets (JSON list of URL templates per source) =====
# Example: barrios/municipios you want to monitor
# Format: source|search_url
SEARCH_TARGETS_FILE=config/search_targets.json

# ===== Notifications =====
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Alert thresholds =====
ALERT_MIN_SCORE_HIGH=80
ALERT_MIN_SCORE_PRICE_DROP=60
ALERT_PRICE_DROP_PCT=5.0

# ===== Auth =====
JWT_SECRET=cambia-esto-por-una-clave-aleatoria-de-32-caracteres-minimo
JWT_EXPIRE_HOURS=8

# ===== Logs =====
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.jsonl
